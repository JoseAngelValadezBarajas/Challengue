{
  "name": "meltwater-redaction-workspace",
  "version": "1.0.0",
  "private": true,
  "description": "Professional full-stack solution for the Meltwater technical exercise.",
  "type": "module",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "setup": "npm install",
    "build": "npm run build --workspaces",
    "dev:api": "npm run dev -w @meltwater-redaction/api",
    "dev:web": "npm run dev -w @meltwater-redaction/web",
    "dev:web:docker": "npm run dev -w @meltwater-redaction/web -- --host 0.0.0.0",
    "dev:all": "concurrently -n api,web -c cyan,green \"npm run dev:api\" \"npm run dev:web\"",
    "all": "npm run dev:all",
    "test": "vitest run",
    "test:watch": "vitest",
    "openapi:validate": "redocly lint docs/openapi.yaml",
    "lint": "eslint .",
    "cli": "npm run dev -w @meltwater-redaction/cli --"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@eslint/js": "^9.28.0",
    "@redocly/cli": "^2.31.6",
    "@types/node": "^22.15.30",
    "@typescript-eslint/eslint-plugin": "^8.33.1",
    "@typescript-eslint/parser": "^8.33.1",
    "concurrently": "^9.2.1",
    "eslint": "^9.28.0",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.33.1",
    "vitest": "^4.1.8",
    "yaml": "^2.9.0"
  }
}
